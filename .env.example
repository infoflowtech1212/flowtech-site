# Contact form email delivery (https://resend.com)
RESEND_API_KEY=
# Where contact form submissions are delivered
CONTACT_TO_EMAIL=info@flowtechapps.com
# Verified sender for Resend (must be a domain you have verified in Resend)
CONTACT_FROM_EMAIL=website@flowtechapps.com
# Canonical site URL for metadata (apex — www redirects here, do not use www)
NEXT_PUBLIC_SITE_URL=https://flowtechapps.com
